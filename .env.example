# ─── Auth (Clerk) ────────────────────────────────────────────────────────────
# Create an application at https://dashboard.clerk.com and enable Email magic
# link + Google as sign-in options.
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_xxx
CLERK_SECRET_KEY=sk_test_xxx

# Where Clerk redirects to. Defaults are fine for local dev.
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up

# ─── Database (Turso / libSQL) ───────────────────────────────────────────────
# Local dev uses a plain SQLite file (no auth token needed).
# Production: libsql://<name>-<org>.turso.io  +  a real auth token.
TURSO_DATABASE_URL=file:./local.db
TURSO_AUTH_TOKEN=

# ─── Film/TV metadata (TMDB) ─────────────────────────────────────────────────
# Free key: https://www.themoviedb.org/settings/api
# Accepts either a v3 API key or a v4 read-access token (Bearer).
TMDB_API_KEY=

# ─── Rate limiting (Upstash Redis) ───────────────────────────────────────────
# Create a Redis database at https://console.upstash.com (REST API).
# If left empty, rate limiting is disabled (fine for local dev).
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# ─── Optional: Watch Tonight AI panel (section 7) ────────────────────────────
# Remove this and the /api/recommend route + watch-tonight UI to ship with no AI.
ANTHROPIC_API_KEY=
